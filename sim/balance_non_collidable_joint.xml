<mujoco>
    <option gravity="0 0 -9.81" timestep="0.002"/>

    
    <asset>
        <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
        <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".0"/>
        <material name="sphere_mat" rgba="1 0.6 0 0.3"/>
        <material name="link_mat" rgba="0.5 0.5 0.5 1"/>
        <material name="box_mat" rgba="1 1 1 0.3"/>
        <texture name="bb8_tex" type="2d" file="bb8_textures/bb8one.png"/>
		<material name="bb8_mat" texture="bb8_tex" texrepeat="1 1" texuniform="false"/>
    </asset>

    <worldbody>
        <!-- Grid floor -->
        <geom name="floor" size="10 10 .05" type="plane" material="grid" friction="3.0 1.5 0.5"/>
        
        <!-- Lighting -->
        <light name="spotlight" mode="targetbodycom" target="sphere_body" diffuse=".8 .8 .8" specular="0.3 0.3 0.3" pos="0 -6 4" cutoff="30"/>
        <light name="top" pos="0 0 5" mode="trackcom"/>
        <light name="side1" pos="5 0 2" dir="-1 0 0" diffuse=".5 .5 .5"/>
        <light name="side2" pos="-5 0 2" dir="1 0 0" diffuse=".5 .5 .5"/>

        <!-- sphere_body stays as-is (has free joint) -->
        <body name="sphere_body" pos="0 0 0.5">
            <joint name="sphere_free" type="free"/>
            <geom name="sphere" type="sphere" size="0.253"  material="sphere_mat" mass="8" contype="1" conaffinity="1" />
            <site name="sphere_center" pos="0 0 0" size="0.01" rgba="1 0 0 0.8"/>
        </body>

        <!-- link is a top-level body (sibling of sphere_body) -->
        <body name="link_body" pos="0 0 0.5">
            <!-- free so it can rotate — equality will enforce position -->
            <joint name="link_free" type="free"/>
            <!-- geom placed so link_bottom site is at the joint center (adjust pos as needed) -->
            <geom name="link" type="cylinder" size="0.01 0.1265" pos="0 0 0" material="link_mat" mass="0.8" contype="0" conaffinity="0"/>
            <site name="link_bottom" pos="0 0 -0.1265" size="0.01" rgba="0 1 0 0.8"/>
            <site name="link_top" pos="0 0 0.1265" size="0.01" rgba="0 1 0 0.8"/>

            <body name="box_weight" pos="0 0 -0.25">
                <geom name="box_weight" type="box" size="0.1 0.1 0.08" material="box_mat" mass="0.001" contype="0" conaffinity="0"/>
                <site name="box_weight_top" pos="0 0 0.08" size="0.01" rgba="1 0 0 0.8"/>
            </body>

            <!-- head (box) attached to link via a joint so it's free relative to the link -->
            <body name="box_body" pos="0 0 0.2065">
                <!-- ball joint gives 3 rotational DOF for the head relative to the link -->
                <joint name="head_joint" type="ball"/>
                <geom name="box" type="box" size="0.14 0.14 0.08" material="box_mat" mass="2" contype="1" conaffinity="1"/>
                <site name="box_bottom" pos="0 0 -0.08" size="0.01" rgba="0 1 0 0.8"/>
            </body>

        </body>

    </worldbody>
    
    <sensor>
        <gyro name="box_weight_gyro_top" site="box_weight_top"/>
    </sensor>
    
    <equality>
        <!-- keep link_bottom coincident with sphere_center (position constraint only) -->
        <connect name="link_to_sphere" site1="sphere_center" site2="link_bottom"/>
        <!-- if you want the box_bottom to coincide with link_top (may be redundant because box is child) -->
        <connect name="link_to_box" site1="box_bottom" site2="link_top"/>
    </equality>

</mujoco>

