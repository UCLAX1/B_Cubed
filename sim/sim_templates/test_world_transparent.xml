<mujoco>
    <option gravity="0 0 0"/>
	<asset>
		<texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
        <texture name = 'highlight' type = '2d' builtin='gradient' rgb1 = '255 255 255' rgb2 = '255 255 255' width = '512' height = '512'/>
        <material name = 'ball' texture = 'highlight' texrepeat ='1 1' texuniform = 'true'/>
        <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".0"/>

		<texture name="bb8_tex" type="2d" file="bb8one.png"/>
		<material name="bb8_mat" texture="bb8_tex" texrepeat="1 1" texuniform="false" rgba="1 1 1 0.3"/>

		<texture name="bb8_head_tex" type="2d" file="bb8head.png"/>
		<material name="bb8_head_mat" texture="bb8_head_tex" texrepeat=".8 1.2" texuniform="false"/>
	</asset>
	<worldbody>
        <light name="spotlight" mode="targetbodycom" target="bb8" diffuse=".8 .8 .8" specular="0.3 0.3 0.3" pos="0 -6 4" cutoff="30"/>
        <light name="top" pos="0 0 2" mode="trackcom"/>

		<body name = 'bb8' pos="0 0 1">
			<joint name = 'bb8_free' type="free" />
			<geom name = "bb8" type = "sphere" size = ".1" material="bb8_mat" rgba="1 1 1 0.3"/>
		</body>

		<body pos= "0 0 1.11" mocap = 'true'>
			<geom name="head" pos="0 0 0" size=".06" type="sphere" rgba="1 1 1 1" contype="0" conaffinity="0" material="bb8_head_mat" euler="90 0 0"/>
		</body>

		<!-- Visual markers for the four motor axes -->
		<body pos="0 0 1" mocap="true">
			<!-- Motor 1 axis: x-z plane, +x direction, 45° from z -->
			<geom name="axis1" type="cylinder" size="0.003 0.2" pos="0 0 0" euler="0 45 0" rgba="1 0 0 0.6" contype="0" conaffinity="0"/>
			<!-- Motor 2 axis: x-z plane, -x direction, 45° from z -->
			<geom name="axis2" type="cylinder" size="0.003 0.2" pos="0 0 0" euler="0 -45 0" rgba="0 1 0 0.6" contype="0" conaffinity="0"/>
			<!-- Motor 3 axis: y-z plane, +y direction, 45° from z -->
			<geom name="axis3" type="cylinder" size="0.003 0.2" pos="0 0 0" euler="45 0 0" rgba="0 0 1 0.6" contype="0" conaffinity="0"/>
			<!-- Motor 4 axis: y-z plane, -y direction, 45° from z -->
			<geom name="axis4" type="cylinder" size="0.003 0.2" pos="0 0 0" euler="-45 0 0" rgba="1 1 0 0.6" contype="0" conaffinity="0"/>
		</body>

	</worldbody>
</mujoco>
