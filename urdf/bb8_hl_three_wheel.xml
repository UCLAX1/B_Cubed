            <body name="a1" pos="0 -0.02 0" quat="0.356335 0.356338 0.610757 -0.610757">
                <inertial pos="0 0 0.033964" quat="0.707107 0 0 0.707107" mass="0.027142"
                    diaginertia="5.8419e-06 5.8158e-06 1.7833e-06" />
                <joint name="a1" pos="0 0 0" axis="0 0 -1" />
                <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="a1" />
                <body name="a2" pos="0 0 0.06" quat="-3.1459e-06 1.89624e-06 0.516236 -0.856446">
