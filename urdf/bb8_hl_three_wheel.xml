                    diaginertia="0.00019635 0.00010341 0.00010341" />
                <joint name="w2" pos="0 0 0" axis="-1 0 0" damping="0.1" />
                <geom type="mesh" mesh="w2" friction="0.2 0.005 0.01" condim="6" />
            </body>
            <!-- <body name="w3" pos="0.125 0.117 0" quat="0.499998 0.5 -0.5 0.500002"> -->
