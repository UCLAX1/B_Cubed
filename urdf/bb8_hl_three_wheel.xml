            </body>
            <!-- <body name="w2" pos="0 0.117 -0.125" quat="0.499998 0.5 -0.5 0.500002"> -->
            <body name="w2" pos="0 0.117 -0.125" quat="0.499998 0.5 -0.5 0.500002">
