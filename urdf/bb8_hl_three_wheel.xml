                diaginertia="0.0059267 0.0098916 0.0059267" />

            <geom type="mesh" rgba="0.79216 0.81961 0.93333 1" mesh="base_link" />
            <geom name="sphere" type="sphere" pos="0 -0.05625 0" size="0.26"
