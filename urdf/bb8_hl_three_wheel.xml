            <!-- </body> -->
        </body>
    </worldbody>

    <actuator>
        <position name="a1_motor" joint="a1" kp="5" kv="1" ctrlrange="-3.14 3.14" />
        <position name="a2_motor" joint="a2" kp="10" kv="5" ctrlrange="0.7 1.5" />
        <position name="h_motor" joint="h" kp="5" kv="1" ctrlrange="-3.14 3.14" />

        <velocity name="bd_motor" joint="base_link_freejoint" kv="5" ctrlrange="-10 10"
            gear="1.375 0 0 0 0 0" />
        <velocity name="bf_motor" joint="base_link_freejoint" kv="5" ctrlrange="-10 10"
            gear="0 1.375 0 0 0 0" />

        <velocity name="br_motor" joint="base_link_freejoint" kv="1" ctrlrange="-2 2"
            gear="0 0 0 0 1 0" />


